<Window x:Class="SimpleAnimate.Views.ExportProgressWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        WindowStartupLocation="CenterOwner"
        Width="420" Height="200"
        ResizeMode="NoResize"
        Topmost="True"
        ShowInTaskbar="False">

    <Border CornerRadius="20" Background="White" Padding="24"
            BorderBrush="#40000000" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="30" ShadowDepth="0" Color="#40000000" Opacity="0.4"/>
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" x:Name="TitleText"
                       Text="&#x1F3AC; Exporting Video..."
                       FontSize="20" FontWeight="Bold" Foreground="#333"
                       HorizontalAlignment="Center" Margin="0,0,0,12"/>

            <ProgressBar Grid.Row="1" x:Name="ExportProgress"
                         Minimum="0" Maximum="100" Value="0"
                         Height="16" Foreground="#69F0AE" Background="#E0E0E0"
                         BorderThickness="0" Margin="0,0,0,8">
                <ProgressBar.Resources>
                    <Style TargetType="ProgressBar">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ProgressBar">
                                    <Border CornerRadius="8" Background="{TemplateBinding Background}">
                                        <Grid>
                                            <Border x:Name="PART_Track"/>
                                            <Border x:Name="PART_Indicator" CornerRadius="8"
                                                    Background="{TemplateBinding Foreground}"
                                                    HorizontalAlignment="Left"/>
                                        </Grid>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ProgressBar.Resources>
            </ProgressBar>

            <TextBlock Grid.Row="2" x:Name="StatusText"
                       Text="Preparing frames..."
                       FontSize="13" Foreground="#888"
                       HorizontalAlignment="Center" Margin="0,0,0,4"/>

            <TextBlock Grid.Row="3" x:Name="PercentText"
                       Text="0%"
                       FontSize="13" FontWeight="SemiBold" Foreground="#666"
                       HorizontalAlignment="Center"/>
        </Grid>
    </Border>
</Window>
