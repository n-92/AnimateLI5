<Window x:Class="SimpleAnimate.Views.AssetLibraryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="&#x1F3A8; Asset Library" Height="500" Width="400"
        WindowStartupLocation="CenterOwner"
        Background="#E8F5E9"
        ShowInTaskbar="True"
        Topmost="False">

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0" Text="Drag pictures onto the canvas!" 
                   FontSize="16" FontWeight="Bold" HorizontalAlignment="Center"
                   Margin="0,0,0,8" Foreground="#333"/>

        <!-- Drop zone to add assets + asset grid -->
        <Border Grid.Row="1" Background="White" CornerRadius="12"
                BorderBrush="#40C4FF" BorderThickness="3"
                AllowDrop="True"
                DragEnter="DropZone_DragEnter"
                DragLeave="DropZone_DragLeave"
                DragOver="DropZone_DragOver"
                Drop="DropZone_Drop"
                x:Name="DropZoneBorder">
            <Grid>
                <!-- Placeholder when empty -->
                <TextBlock x:Name="DropHint"
                           Text="&#x1F4E5;&#xA;Drop images here to add,&#xA;then drag them to the canvas!"
                           FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"
                           TextAlignment="Center" Foreground="#AAAAAA"/>

                <!-- Asset thumbnails -->
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <ItemsControl x:Name="AssetList">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="6" CornerRadius="8" BorderBrush="#CCCCCC" BorderThickness="1"
                                        Background="#FAFAFA" Cursor="Hand"
                                        MouseMove="Asset_MouseMove"
                                        ToolTip="Drag me to the canvas!">
                                    <Grid Width="100" Height="100">
                                        <Image Source="{Binding}" Stretch="Uniform" Margin="4"
                                               IsHitTestVisible="False"/>
                                        <!-- Remove button -->
                                        <Button Content="&#x274C;" FontSize="10"
                                                HorizontalAlignment="Right" VerticalAlignment="Top"
                                                Width="20" Height="20" Padding="0" Margin="2"
                                                Click="RemoveAsset_Click" Tag="{Binding}"
                                                Cursor="Hand" Background="#EF9A9A" BorderThickness="0"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>

        <!-- Bottom button -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,12,0,0">
            <Button Content="&#x2795; Add Files" FontSize="16" FontWeight="Bold"
                    Padding="16,8" Margin="8,0" Cursor="Hand"
                    Background="#69F0AE" Click="AddFiles_Click">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="10"
                                BorderThickness="2" BorderBrush="#66000000" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </StackPanel>
    </Grid>
</Window>
