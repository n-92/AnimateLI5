<Window x:Class="SimpleAnimate.Views.SplashWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        WindowStartupLocation="CenterScreen"
        Width="600" Height="650"
        ResizeMode="NoResize"
        Topmost="True"
        ShowInTaskbar="False">
    <Window.Resources>
        <DropShadowEffect x:Key="SplashShadow" BlurRadius="40" ShadowDepth="0"
                          Color="#40000000" Opacity="0.5"/>
    </Window.Resources>

    <Border CornerRadius="30" Background="White" Padding="20"
            Effect="{StaticResource SplashShadow}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Image Grid.Row="0"
                   Source="/Assets/splash_logo.png"
                   Stretch="Uniform"
                   Margin="20"
                   RenderOptions.BitmapScalingMode="HighQuality"/>

            <StackPanel Grid.Row="1" HorizontalAlignment="Center" Margin="0,0,0,10">
                <TextBlock Text="Loading..." FontSize="16" FontWeight="SemiBold"
                           Foreground="#888" HorizontalAlignment="Center"/>
                <ProgressBar IsIndeterminate="True" Width="200" Height="6" Margin="0,8,0,0"
                             Foreground="#69F0AE" Background="#E0E0E0"
                             BorderThickness="0"/>
            </StackPanel>

            <Border Grid.Row="2" Background="#F5F5F5" CornerRadius="0,0,10,10"
                    Padding="0,10,0,8" Margin="-20,-1,-20,-20">
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock HorizontalAlignment="Center" FontSize="13" Foreground="#999"
                               Margin="0,0,0,4">
                        <Run Text="Made by"/>
                    </TextBlock>
                    <TextBlock HorizontalAlignment="Center">
                        <Hyperlink x:Name="GitHubLink" FontSize="15" FontWeight="Bold"
                                   Foreground="#6C63FF" TextDecorations="None"
                                   NavigateUri="https://github.com/n-92"
                                   RequestNavigate="GitHubLink_RequestNavigate">
                            <Run Text="github.com/n-92"/>
                        </Hyperlink>
                    </TextBlock>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
